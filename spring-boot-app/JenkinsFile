pipeline {
  agent {
    docker {
      image 'jibin321/maven-docker-agent:v2'
      args '--user root -v /var/run/docker.sock:/var/run/docker.sock'
    }
  }

  
  stages {
    stage('Checkout') {
      steps {
        sh 'echo passed'
      }
    }
    stage('Build and Test') {
      steps {
        sh 'ls -ltr'
        sh 'cd spring-boot-app && mvn clean package'
      }
    }
    stage('Static Code Analysis') {
      environment {
        SONAR_URL = "http://3.80.122.105:9000"
      }
      steps {
        withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
          sh 'cd spring-boot-app && mvn sonar:sonar -Dsonar.login=$SONAR_AUTH_TOKEN -Dsonar.host.url=${SONAR_URL}'
        }
      }
    }
    stage('Build and Push Docker Image') {
      environment {
        DOCKER_IMAGE = "stelabiju/ultimate-cicd:${BUILD_NUMBER}"
        REGISTRY_CREDENTIALS = credentials('docker-cred')
      }
      steps {
        script {
            sh 'cd spring-boot-app && docker build -t ${DOCKER_IMAGE} .'
            def dockerImage = docker.image("${DOCKER_IMAGE}")
            docker.withRegistry('https://index.docker.io/v1/', "docker-cred") {
                dockerImage.push()
            }
        }
      }
    }
    stage('Update Deployment File') {
    environment {
        GIT_REPO_NAME = "java-maven-sonar-argocd"
        GIT_USER_NAME = "stelabiju"
    }
    steps {
        withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
            sh '''
                echo "Current Directory:"
                pwd

                echo "Repository Contents:"
                ls -la
                git config --global --add safe.directory /var/lib/jenkins/workspace/Java_Maven
                git config --global user.email "stelabiju@gmail.com"
                git config --global user.name "stelabiju"

                BUILD_NUMBER=${BUILD_NUMBER}

                sed -i "s|stelabiju/ultimate-cicd:.*|stelabiju/ultimate-cicd:${BUILD_NUMBER}|g" spring-boot-app-manifests/deployment.yml

                git status

                git add spring-boot-app-manifests/deployment.yml

                git commit -m "Update deployment image to version ${BUILD_NUMBER}" || echo "No changes to commit"

                git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME}.git HEAD:main
            '''
        }
    }
  }
 }
}
